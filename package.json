  "devDependencies": {
    "@types/node": "26.1.1",
    "@typescript-eslint/eslint-plugin": "8.63.0",
    "@typescript-eslint/parser": "8.63.0",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "nodemon": "3.1.14",
    "pino-pretty": "13.1.3",
    "prettier": "3.9.5",
    "tsx": "4.23.0"
